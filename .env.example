# Supabase project URL for browser auth and profile reads.
VITE_SUPABASE_URL=
# Supabase anon/public API key used by the client SDK.
VITE_SUPABASE_ANON_KEY=
# Base URL for the Cloudflare Pages Functions API that powers dashboard calls.
# Leave blank when the frontend is served behind the same origin as the worker routes.
VITE_API_BASE=

# Optional Vite-only fallback account for dashboard UI work without a live Supabase session.
VITE_DEV_AUTH_EMAIL=dev@nick.local
VITE_DEV_AUTH_PASSWORD=nick-dev-password

# Optional: enabled automatically by the root Playwright harness.
VITE_E2E_MOCKS=false
